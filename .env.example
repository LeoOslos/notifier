TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Opcionales (valores por defecto mostrados)
# DB_PATH=/home/leoadmin/notifier/queue.db
# POLL_INTERVAL=2000
# MAX_RETRIES=3
# BATCH_SIZE=10
# TTS_PORT=9876
# TTS_LANG=es
# DISCOVERY_INTERVAL=300000   # redescubrimiento mDNS cada 5 min (en ms)

# Hook coreográfico: ejecutable a correr cuando una fila analyze=1 pasa a 'sent'.
# Recibe el id del incidente como único argumento. Vacío = no-op (default).
# ANALYZE_HOOK_CMD=/home/leoadmin/analyzer/run_analyzer.sh
